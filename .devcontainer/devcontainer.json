// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/ubuntu
{
    "name": "devcontainer-ubuntu-go",
    "build": {
        "dockerfile": "Dockerfile",
        "args": {
            "TZ": "${localEnv:TZ:Etc/UTC}"
        }
    },
    "features": {
        "ghcr.io/devcontainers/features/go:1": {
            "version": "1.25"
        },
        "ghcr.io/devcontainers/features/node:1": {},
        "ghcr.io/devcontainers-extra/features/npm-package:1": {}
    },
    "containerEnv": {
        "CLAUDE_CONFIG_DIR": "/home/vscode/.claude",
        "GIT_AUTHOR_NAME": "${localEnv:GIT_AUTHOR_NAME}",
        "GIT_AUTHOR_EMAIL": "${localEnv:GIT_AUTHOR_EMAIL}",
        "GIT_COMMITTER_NAME": "${localEnv:GIT_COMMITTER_NAME}",
        "GIT_COMMITTER_EMAIL": "${localEnv:GIT_COMMITTER_EMAIL}"
    },
    "remoteEnv": {
        "SSH_AUTH_SOCK": ""
    },
    "mounts": [
        "source=claude-${devcontainerId},target=/home/vscode/.claude,type=volume",
        "source=config-${devcontainerId},target=/home/vscode/.config,type=volume"    
    ],
    "postCreateCommand": {
        "install-claude": "curl -fsSL https://claude.ai/install.sh | bash",
        "install-goimports": "go install golang.org/x/tools/cmd/goimports@latest",
        "install-golangci-lint": "go install github.com/golangci/golangci-lint/cmd/golangci-lint@latest"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "anthropic.claude-code",
                "golang.go",
                "esbenp.prettier-vscode",
                "redhat.vscode-yaml"
            ],
            "settings": {
                "claudeCode.allowDangerouslySkipPermissions": true,
                "claudeCode.initialPermissionMode": "bypassPermissions",
                "remote.SSH.enableAgentForwarding": false
            }
        }
    }
}